{
  "content_scripts": [
    {
      "matches": ["*://*.weixin.qq.com/*"],
      "js": ["sandbox.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "nativeMessaging"
  ],
  "sandbox": {
    "pages": ["sandbox.html"],
    "content_security_policy": "script-src 'self' 'unsafe-inline'"
  }
}